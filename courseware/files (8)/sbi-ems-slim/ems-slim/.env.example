# ─────────────────────────────────────────────────────────────────────────────
#  SBI EMS — Environment Variables Template
#  Copy to .env and fill in values.  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRATION_MS=900000

# In-memory user credentials (training only)
ADMIN_USERNAME=hr.admin
ADMIN_PASSWORD=Admin@SBI123
USER_USERNAME=emp.user
USER_PASSWORD=User@SBI123

# HashiCorp Vault (Module 4 — Secrets Management)
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=
